# Copie para .env (NUNCA comite o .env). No GitHub Actions, estes viram
# Repository Secrets criptografados.

# --- Destinatario da newsletter ---
RECIPIENT_EMAIL=seu_email@gmail.com

# --- Gmail API (OAuth) ---
# Local: use credentials.json + token.json (fluxo OAuth no navegador na 1a vez).
# Actions: preencha os 3 valores abaixo como secrets.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- Gemini (OPCIONAL) ---
# Resumos por IA. Sem esta chave, o newsletter usa fallback deterministico
# (meta-descricao das paginas) e continua funcionando normalmente.
# Chave gratuita em https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Kie.ai (OPCIONAL) ---
# Gera a "capa" duotone da edicao. Sem esta chave, o e-mail usa uma faixa
# duotone em CSS no lugar. KIE_MODEL e opcional (default google/nano-banana).
KIE_API_KEY=
KIE_MODEL=google/nano-banana
